# Bot token from @BotFather
BOT_TOKEN=

# Telegram IDs of administrators, comma-separated (find yours via @userinfobot)
ADMIN_IDS=

# Interface language: picks config/messages.<locale>.toml. Shipped: en, ru
LOCALE=en

# Liveness probe port: GET /healthz -> 200 while the bot is alive (default 8080)
HEALTH_PORT=8080
